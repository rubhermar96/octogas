---
import fs from "node:fs";
import path from "node:path";
import Layout from "../../../layouts/Layout.astro";
import MainMap from "../../../components/Map/MainMap";
import MunicipioTop from "../../../components/Municipio/MunicipioTop";
import AdSlot from "../../../components/AdSlot.astro";
import { slugify } from "../../../lib/slug";
import { stationUrl, provinceUrl } from "../../../lib/stationUrl";
import { titleCase } from "../../../lib/format";
import type { GasStation } from "../../../types/gasolinera";

interface Sibling {
    name: string;
    slug: string;
    count: number;
}

export async function getStaticPaths() {
    const dataPath = path.resolve("public/data/stations.json");
    const stations = JSON.parse(fs.readFileSync(dataPath, "utf-8")) as GasStation[];

    // Agrupa por provincia y municipio.
    const groups: Record<string, Record<string, GasStation[]>> = {};
    stations.forEach((station) => {
        const province = station.province;
        const city = station.city;
        if (!province || !city) return;
        (groups[province] ??= {})[city] ??= [];
        groups[province][city].push(station);
    });

    // Lista de municipios por provincia (para enlaces internos), ordenada por nº de estaciones.
    const provinceMunis: Record<string, Sibling[]> = {};
    for (const province in groups) {
        provinceMunis[province] = Object.entries(groups[province])
            .map(([name, list]) => ({ name, slug: slugify(name), count: list.length }))
            .sort((a, b) => b.count - a.count);
    }

    const paths = [];
    for (const provinceName in groups) {
        for (const municipalityName in groups[provinceName]) {
            const provSlug = slugify(provinceName);
            const muniSlug = slugify(municipalityName);
            if (!provSlug || !muniSlug) continue;

            const siblings = provinceMunis[provinceName]
                .filter((m) => m.slug !== muniSlug)
                .slice(0, 24);

            paths.push({
                params: { provincia: provSlug, municipio: muniSlug },
                props: {
                    provinceName,
                    municipalityName,
                    provSlug,
                    stations: groups[provinceName][municipalityName],
                    siblings,
                },
            });
        }
    }
    return paths;
}

const { provinceName, municipalityName, provSlug, stations, siblings } = Astro.props as {
    provinceName: string;
    municipalityName: string;
    provSlug: string;
    stations: GasStation[];
    siblings: Sibling[];
};

// Nombre de provincia en formato "Título" (el dato viene en mayúsculas).
const provLabel = titleCase(provinceName);

// --- Estadísticas para contenido y FAQ ---
type FuelKey = "sp95" | "sp98" | "diesel" | "glp";
const min = (key: FuelKey) => {
    const vals = stations.map((s) => s.prices[key]).filter((p): p is number => p != null);
    return vals.length ? Math.min(...vals) : null;
};
const avg = (key: FuelKey) => {
    const vals = stations.map((s) => s.prices[key]).filter((p): p is number => p != null);
    return vals.length ? vals.reduce((a, b) => a + b, 0) / vals.length : null;
};
const fmt = (n: number | null) => (n != null ? n.toFixed(3) : "—");

const minSp95 = min("sp95");
const minDiesel = min("diesel");
const avgSp95 = avg("sp95");
const avgDiesel = avg("diesel");

// Precio medio de cada combustible disponible en el municipio.
const fuelAverages = (
    [
        ["sp95", "SP95"],
        ["sp98", "SP98"],
        ["diesel", "Diésel"],
        ["glp", "GLP"],
    ] as [FuelKey, string][]
)
    .map(([key, label]) => ({ key, label, avg: avg(key) }))
    .filter((x) => x.avg != null);

const cheapestSp95Station = stations
    .filter((s) => s.prices.sp95 != null)
    .sort((a, b) => a.prices.sp95! - b.prices.sp95!)[0];

const centerLat = stations.reduce((s, x) => s + x.lat, 0) / stations.length;
const centerLng = stations.reduce((s, x) => s + x.lng, 0) / stations.length;

const explorerUrl = `/explorador?mode=municipality&prov=${encodeURIComponent(
    provinceName
)}&city=${encodeURIComponent(municipalityName)}`;

const updated = new Date().toLocaleDateString("es-ES", {
    day: "numeric",
    month: "long",
    year: "numeric",
});

const pageTitle = `Gasolineras baratas en ${municipalityName} (${provLabel}) — Precios hoy | OCTO`;
const pageDescription = `Compara el precio de la gasolina 95 y el diésel en ${stations.length} gasolineras de ${municipalityName}, ${provLabel}. La más barata desde ${fmt(minSp95)} €/L. Datos oficiales actualizados.`;

// --- Datos estructurados (FAQ + Breadcrumb) ---
const faq = [
    {
        q: `¿Cuál es la gasolinera más barata en ${municipalityName}?`,
        a: cheapestSp95Station
            ? `Actualmente la más barata para Gasolina 95 es ${cheapestSp95Station.name} (${cheapestSp95Station.address}), a ${fmt(minSp95)} €/L.`
            : `Consulta el listado actualizado de gasolineras en ${municipalityName} para ver la más barata.`,
    },
    {
        q: `¿Cuánto cuesta la gasolina 95 en ${municipalityName}?`,
        a: `El precio medio de la Gasolina 95 en ${municipalityName} es de ${fmt(avgSp95)} €/L, siendo el más bajo ${fmt(minSp95)} €/L.`,
    },
    {
        q: `¿Cuánto cuesta el diésel en ${municipalityName}?`,
        a: `El precio medio del Gasóleo A (diésel) en ${municipalityName} es de ${fmt(avgDiesel)} €/L, con un mínimo de ${fmt(minDiesel)} €/L.`,
    },
    {
        q: `¿Cuántas gasolineras hay en ${municipalityName}?`,
        a: `Hay ${stations.length} estaciones de servicio con precios disponibles en ${municipalityName}.`,
    },
    {
        q: `¿Con qué frecuencia se actualizan los precios?`,
        a: `Los precios se actualizan a diario a partir de los datos oficiales del Ministerio para la Transición Ecológica.`,
    },
];

const faqJsonLd = {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: faq.map((f) => ({
        "@type": "Question",
        name: f.q,
        acceptedAnswer: { "@type": "Answer", text: f.a },
    })),
};

const breadcrumbJsonLd = {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
        { "@type": "ListItem", position: 1, name: "Inicio", item: new URL("/", Astro.site).href },
        {
            "@type": "ListItem",
            position: 2,
            name: "Buscar municipio",
            item: new URL("/municipios", Astro.site).href,
        },
        {
            "@type": "ListItem",
            position: 3,
            name: `${municipalityName} (${provLabel})`,
            item: Astro.url.href,
        },
    ],
};
---

<Layout title={pageTitle} description={pageDescription}>
    <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} slot="head" />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} slot="head" />

    <div class="page-container">
        <div class="content-wrapper">
            <nav class="breadcrumb" aria-label="Migas de pan">
                <a href="/">Inicio</a>
                <span>›</span>
                <a href={provinceUrl(provinceName)}>{titleCase(provinceName)}</a>
                <span>›</span>
                <span class="current">{municipalityName}</span>
            </nav>

            <header class="page-header">
                <h1>Gasolineras baratas en {municipalityName}</h1>
                <p class="subtitle">
                    Precios de gasolina y diésel en {municipalityName}, {provLabel}.
                    Comparamos {stations.length} estaciones de servicio para que encuentres la
                    más barata. <span class="updated">Actualizado el {updated}.</span>
                </p>
            </header>

            <section class="stats-bar" aria-label="Precio medio por combustible">
                <div class="stat">
                    <span class="stat-label">Estaciones</span>
                    <span class="stat-value">{stations.length}</span>
                </div>
                {
                    fuelAverages.map((f) => (
                        <div class="stat">
                            <span class="stat-label">Media {f.label}</span>
                            <span class="stat-value muted">{fmt(f.avg)} <small>€/L</small></span>
                        </div>
                    ))
                }
            </section>

            <MunicipioTop client:load stations={stations} explorerUrl={explorerUrl} />

            <AdSlot slot="" label="Publicidad" minHeight={120} />

            <section class="map-section">
                <div class="map-wrapper">
                    <MainMap
                        client:only="react"
                        stations={stations}
                        initialCenter={[centerLat, centerLng]}
                        initialZoom={13}
                        disableGeolocation={true}
                    />
                </div>
            </section>

            <section class="faq">
                <h2>Preguntas frecuentes sobre el precio del combustible en {municipalityName}</h2>
                {
                    faq.map((f) => (
                        <details class="faq-item">
                            <summary>{f.q}</summary>
                            <p>{f.a}</p>
                        </details>
                    ))
                }
            </section>

            <section class="all-stations">
                <h2>Todas las gasolineras de {municipalityName}</h2>
                <div class="station-link-grid">
                    {
                        stations.map((s) => (
                            <a href={stationUrl(s)} class="station-link">
                                <span class="sl-name">{/^n[ºo°]/i.test(s.brand) || /^\d/.test(s.brand) ? s.address : s.brand}</span>
                                <span class="sl-meta">
                                    {s.prices.sp95 != null && <span class="sl-price">{fmt(s.prices.sp95)} €/L</span>}
                                </span>
                            </a>
                        ))
                    }
                </div>
            </section>

            {
                siblings.length > 0 && (
                    <section class="siblings">
                        <h2>Gasolineras en otros municipios de {provLabel}</h2>
                        <div class="sibling-grid">
                            {siblings.map((m) => (
                                <a href={`/gasolineras-baratas/${provSlug}/${m.slug}`} class="sibling-link">
                                    {m.name}
                                    <span>{m.count}</span>
                                </a>
                            ))}
                        </div>
                    </section>
                )
            }
        </div>
    </div>
</Layout>

<style>
    .page-container {
        padding: 5rem 2rem 3rem;
        min-height: 100vh;
        background-color: var(--bg);
        color: var(--text);
    }

    .content-wrapper {
        max-width: 1500px;
        margin: 0 auto;
    }

    .breadcrumb {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.8rem;
        color: var(--text-muted);
        margin-bottom: 1.5rem;
        flex-wrap: wrap;
    }
    .breadcrumb a {
        color: var(--text-muted);
        text-decoration: none;
    }
    .breadcrumb a:hover {
        color: var(--primary);
    }
    .breadcrumb .current {
        color: var(--text);
        font-weight: 600;
    }

    .page-header {
        margin-bottom: 2rem;
    }
    h1 {
        font-family: var(--font-header);
        font-size: clamp(1.8rem, 4vw, 2.6rem);
        margin-bottom: 0.75rem;
        line-height: 1.1;
    }
    .subtitle {
        color: var(--text-muted);
        font-size: 1.05rem;
        line-height: 1.6;
        max-width: 760px;
    }
    .updated {
        color: var(--primary);
        font-weight: 600;
    }

    .stats-bar {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
        gap: 1rem;
        margin-bottom: 3rem;
    }
    .stat {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 0.875rem;
        padding: 1.1rem 1.25rem;
        display: flex;
        flex-direction: column;
        gap: 0.35rem;
    }
    .stat-label {
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: var(--text-muted);
        font-weight: 700;
    }
    .stat-value {
        font-family: var(--font-header);
        font-size: 1.5rem;
        font-weight: 800;
        color: var(--primary);
    }
    .stat-value.muted {
        color: var(--text);
    }
    .stat-value small {
        font-size: 0.8rem;
        font-weight: 600;
        color: var(--text-muted);
    }

    section h2 {
        font-family: var(--font-header);
        font-size: 1.4rem;
        margin-bottom: 1.5rem;
    }

    .stations-list {
        margin-bottom: 2rem;
    }
    .list-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 1rem;
    }
    .station-card {
        background: var(--surface);
        padding: 1.25rem;
        border-radius: 0.875rem;
        border: 1px solid var(--border);
        display: flex;
        align-items: flex-start;
        gap: 1rem;
        transition: border-color 0.2s, transform 0.2s;
    }
    .station-card:hover {
        border-color: rgba(52, 211, 153, 0.4);
        transform: translateY(-2px);
    }
    .rank {
        font-family: var(--font-header);
        font-size: 1.25rem;
        font-weight: 800;
        color: var(--text-muted);
        opacity: 0.5;
    }
    .details {
        flex: 1;
        min-width: 0;
    }
    .details h3 {
        font-size: 1rem;
        margin-bottom: 0.1rem;
    }
    .brand {
        font-size: 0.7rem;
        text-transform: uppercase;
        color: var(--primary);
        font-weight: 700;
        margin-bottom: 0.4rem;
    }
    .address {
        font-size: 0.8rem;
        color: var(--text-muted);
        margin-bottom: 0.75rem;
    }
    .prices {
        display: flex;
        gap: 0.5rem;
        margin-bottom: 0.75rem;
    }
    .price-badge {
        display: flex;
        flex-direction: column;
        align-items: center;
        background: rgba(52, 211, 153, 0.1);
        padding: 0.4rem 0.7rem;
        border-radius: 0.6rem;
        flex: 1;
    }
    .price-badge.alt {
        background: var(--bg);
    }
    .ptype {
        font-size: 0.6rem;
        font-weight: 700;
        color: var(--text-muted);
    }
    .price {
        font-weight: 800;
        font-size: 1rem;
        color: var(--text);
    }
    .route {
        font-size: 0.78rem;
        font-weight: 700;
        color: var(--secondary);
        text-decoration: none;
    }
    .route:hover {
        text-decoration: underline;
    }
    .cta-explore {
        display: inline-block;
        margin-top: 1.5rem;
        padding: 0.8rem 1.5rem;
        background: var(--primary);
        color: var(--bg);
        font-weight: 700;
        border-radius: 0.75rem;
        text-decoration: none;
    }
    .cta-explore:hover {
        box-shadow: 0 0 20px rgba(52, 211, 153, 0.4);
    }

    .map-section {
        height: 460px;
        margin: 1rem 0 3rem;
        border-radius: 1rem;
        overflow: hidden;
        border: 1px solid var(--border);
    }
    .map-wrapper {
        height: 100%;
        width: 100%;
    }

    .faq {
        margin-bottom: 3rem;
    }
    .faq-item {
        border: 1px solid var(--border);
        border-radius: 0.75rem;
        margin-bottom: 0.75rem;
        background: var(--surface);
        overflow: hidden;
    }
    .faq-item summary {
        padding: 1rem 1.25rem;
        font-weight: 700;
        cursor: pointer;
        color: var(--text);
        list-style: none;
    }
    .faq-item summary::-webkit-details-marker {
        display: none;
    }
    .faq-item summary::after {
        content: "+";
        float: right;
        color: var(--primary);
        font-weight: 800;
    }
    .faq-item[open] summary::after {
        content: "−";
    }
    .faq-item p {
        padding: 0 1.25rem 1.1rem;
        color: var(--text-muted);
        line-height: 1.6;
    }

    .all-stations {
        margin-bottom: 3rem;
    }
    .station-link-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
        gap: 0.6rem;
    }
    .station-link {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.5rem;
        padding: 0.75rem 1rem;
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 0.7rem;
        text-decoration: none;
        color: var(--text);
        transition: border-color 0.2s, transform 0.2s;
    }
    .station-link:hover {
        border-color: var(--primary);
        transform: translateY(-1px);
    }
    .sl-name {
        font-size: 0.88rem;
        font-weight: 600;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }
    .sl-price {
        font-size: 0.78rem;
        font-weight: 700;
        color: var(--primary);
        flex-shrink: 0;
    }

    .siblings {
        margin-bottom: 3rem;
    }
    .sibling-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
        gap: 0.6rem;
    }
    .sibling-link {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0.7rem 1rem;
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 0.6rem;
        text-decoration: none;
        color: var(--text);
        font-size: 0.875rem;
        transition: border-color 0.2s, color 0.2s;
    }
    .sibling-link:hover {
        border-color: var(--primary);
        color: var(--primary);
    }
    .sibling-link span {
        font-size: 0.7rem;
        color: var(--text-muted);
        background: var(--bg);
        padding: 0.1rem 0.45rem;
        border-radius: 999px;
    }
</style>
