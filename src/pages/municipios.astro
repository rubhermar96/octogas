---
import Layout from "../layouts/Layout.astro";
import MunicipalitySearch from "../components/Explorer/MunicipalitySearch";

// Ciudades principales (nombre visible + ruta a su página de municipio).
const mainCities: { name: string; path: string }[] = [
    { name: "Madrid", path: "/gasolineras-baratas/madrid/madrid" },
    { name: "Barcelona", path: "/gasolineras-baratas/barcelona/barcelona" },
    { name: "Valencia", path: "/gasolineras-baratas/valencia-valencia/valencia" },
    { name: "Sevilla", path: "/gasolineras-baratas/sevilla/sevilla" },
    { name: "Zaragoza", path: "/gasolineras-baratas/zaragoza/zaragoza" },
    { name: "Málaga", path: "/gasolineras-baratas/malaga/malaga" },
    { name: "Murcia", path: "/gasolineras-baratas/murcia/murcia" },
    { name: "Palma de Mallorca", path: "/gasolineras-baratas/balears-illes/palma-de-mallorca" },
    { name: "Las Palmas de Gran Canaria", path: "/gasolineras-baratas/palmas-las/palmas-de-gran-canaria-las" },
    { name: "Córdoba", path: "/gasolineras-baratas/cordoba/cordoba" },
    { name: "Valladolid", path: "/gasolineras-baratas/valladolid/valladolid" },
    { name: "Alicante", path: "/gasolineras-baratas/alicante/alicantealacant" },
    { name: "Cartagena", path: "/gasolineras-baratas/murcia/cartagena" },
    { name: "Jerez de la Frontera", path: "/gasolineras-baratas/cadiz/jerez-de-la-frontera" },
    { name: "Bilbao", path: "/gasolineras-baratas/bizkaia/bilbao" },
    { name: "Granada", path: "/gasolineras-baratas/granada/granada" },
];
---

<Layout
    title="Buscar gasolineras por municipio en España | OCTO"
    description="Busca tu municipio y compara al instante los precios de gasolina y diésel de las gasolineras de tu zona. Datos oficiales actualizados de toda España."
    hideSidebar={true}
>
    <main class="municipios-page">
        <div class="background-effects">
            <div class="blob blob-1"></div>
            <div class="blob blob-2"></div>
        </div>

        <section class="search-container">
            <header class="page-header">
                <a href="/" class="back-link">
                    <span class="material-symbols-outlined">arrow_back</span>
                    Volver al inicio
                </a>
                <h1 class="title">Encuentra tu <span class="text-gradient">gasolinera</span></h1>
                <p class="subtitle">Escribe el nombre de tu pueblo o ciudad para comparar los precios exactos del combustible.</p>
            </header>

            <div class="search-box">
                <MunicipalitySearch client:only="react" />
            </div>

            <div class="location-cta">
                <span class="divider-text">o</span>
                <a href="/explorador?mode=location" class="location-button">
                    <span class="material-symbols-outlined">my_location</span>
                    Usar mi ubicación en tiempo real
                </a>
            </div>

            <div class="quick-links">
                <h2>Ciudades principales</h2>
                <div class="cities-grid">
                    {
                        mainCities.map((c) => (
                            <a href={c.path} class="city-card">
                                <span class="city-name">{c.name}</span>
                                <span class="city-icon material-symbols-outlined">location_city</span>
                            </a>
                        ))
                    }
                </div>
            </div>
        </section>
    </main>
</Layout>

<style>
    .municipios-page {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 6rem 2rem 2rem 2rem;
        position: relative;
        overflow: hidden;
    }

    .background-effects {
        position: fixed;
        inset: 0;
        z-index: -1;
        overflow: hidden;
        pointer-events: none;
    }

    .blob {
        position: absolute;
        width: 600px;
        height: 600px;
        border-radius: 50%;
        filter: blur(100px);
        opacity: 0.15;
        z-index: -1;
    }

    .blob-1 {
        top: -100px;
        right: -100px;
        background-color: var(--primary);
    }

    .blob-2 {
        bottom: -200px;
        left: -200px;
        background-color: #3b82f6; /* A matching blue */
    }

    .search-container {
        width: 100%;
        max-width: 1100px;
        display: flex;
        flex-direction: column;
        gap: 3rem;
        z-index: 1;
    }

    .page-header {
        text-align: center;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1rem;
    }

    .back-link {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        color: var(--text-muted);
        text-decoration: none;
        font-weight: 600;
        transition: color 0.2s;
        align-self: flex-start;
        margin-bottom: 1rem;
    }

    .back-link:hover {
        color: var(--primary);
    }

    .title {
        font-size: clamp(2.5rem, 5vw, 4rem);
        font-weight: 800;
        color: var(--text);
        margin: 0;
        line-height: 1.1;
    }

    .text-gradient {
        background: linear-gradient(135deg, var(--primary) 0%, #3b82f6 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    .subtitle {
        font-size: 1.1rem;
        color: var(--text-muted);
        max-width: 600px;
        margin: 0 auto;
        line-height: 1.6;
    }

    .search-box {
        width: 100%;
        margin-top: 1rem;
    }

    .location-cta {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1rem;
        margin-top: 1.5rem;
    }

    .divider-text {
        color: var(--text-muted);
        font-size: 0.9rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
    }

    .location-button {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.85rem 1.5rem;
        border-radius: 0.75rem;
        background-color: var(--surface);
        border: 1px solid var(--border);
        color: var(--text);
        font-weight: 700;
        text-decoration: none;
        transition: all 0.2s;
    }

    .location-button:hover {
        border-color: var(--primary);
        color: var(--primary);
        transform: translateY(-2px);
    }

    .quick-links {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
        margin-top: 2rem;
    }

    .quick-links h2 {
        font-size: 1.25rem;
        color: var(--text);
        font-weight: 700;
        margin: 0;
    }

    .cities-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
        gap: 1rem;
    }

    .city-card {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 1.25rem;
        background-color: var(--surface);
        border: 1px solid var(--border);
        border-radius: 1rem;
        text-decoration: none;
        color: var(--text);
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .city-card:hover {
        border-color: var(--primary);
        box-shadow: 0 10px 30px rgba(54, 211, 153, 0.15);
        transform: translateY(-4px);
    }

    .city-name {
        font-weight: 700;
        font-size: 1.1rem;
    }

    .city-icon {
        color: var(--primary);
        opacity: 0.7;
        transition: opacity 0.2s;
    }

    .city-card:hover .city-icon {
        opacity: 1;
    }
</style>
