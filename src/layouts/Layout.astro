---
// Fuentes self-hosted (sin llamadas a Google Fonts -> mejor rendimiento y privacidad)
import "@fontsource/geist-sans/300.css";
import "@fontsource/geist-sans/400.css";
import "@fontsource/geist-sans/500.css";
import "@fontsource/geist-sans/600.css";
import "@fontsource/geist-sans/700.css";
import "@fontsource/unbounded/700.css";
import "../styles/global.css";
import styles from "../styles/Layout.module.css";

import { SITE } from "../consts";
import ConsentBanner from "../components/ConsentBanner.astro";

interface Props {
    title: string;
    description?: string;
    ogImage?: string;
    ogType?: string;
    noindex?: boolean;
    hideSidebar?: boolean;
    hideHeaderLogo?: boolean;
}

const {
    title,
    description = SITE.description,
    ogImage = SITE.ogImage,
    ogType = "website",
    noindex = false,
    hideSidebar = false,
    hideHeaderLogo = false,
} = Astro.props;

const isHome = Astro.url.pathname === "/";

// Canonical y URLs absolutas (Astro.site = dominio de astro.config).
const canonicalURL = new URL(Astro.url.pathname, Astro.site).href;
const ogImageURL = new URL(ogImage, Astro.site).href;

// Datos estructurados globales (Organización + buscador del sitio).
const orgJsonLd = {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: SITE.name,
    url: Astro.site?.href,
    description: SITE.description,
    inLanguage: "es-ES",
    potentialAction: {
        "@type": "SearchAction",
        target: {
            "@type": "EntryPoint",
            urlTemplate: new URL("/municipios?q={search_term_string}", Astro.site).href,
        },
        "query-input": "required name=search_term_string",
    },
};
---

<!doctype html>
<html lang="es">
    <head>
        <meta charset="utf-8" />
        <meta content="width=device-width, initial-scale=1.0" name="viewport" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

        <!-- SEO básico -->
        <title>{title}</title>
        <meta name="description" content={description} />
        <link rel="canonical" href={canonicalURL} />
        {noindex && <meta name="robots" content="noindex, nofollow" />}
        <meta name="theme-color" content="#34d399" />
        <meta name="generator" content={Astro.generator} />

        <!-- Open Graph -->
        <meta property="og:type" content={ogType} />
        <meta property="og:site_name" content={SITE.name} />
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:url" content={canonicalURL} />
        <meta property="og:image" content={ogImageURL} />
        <meta property="og:locale" content={SITE.locale} />

        <!-- Twitter -->
        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:title" content={title} />
        <meta name="twitter:description" content={description} />
        <meta name="twitter:image" content={ogImageURL} />

        <!-- Datos estructurados globales -->
        <script type="application/ld+json" set:html={JSON.stringify(orgJsonLd)} />

        <!-- Icons (Material Symbols) -->
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&display=swap"
            rel="stylesheet"
        />
        <slot name="head" />
    </head>
    <body class={`custom-scrollbar ${isHome ? 'home-page' : ''}`}>
        <!-- Floating Header -->
        <header class={styles.header} id="main-header">
            {!hideHeaderLogo && (
            <div class={styles.headerLeft} id="header-logo">
                <a href="/">
                    <img src="/images/logo-octo.png" alt="OCTO" class={styles.headerLogo} />
                </a>
            </div>
            )}

            <div class={styles.headerControls}>
                <button class={styles.themeToggle} id="theme-toggle" aria-label="Toggle Theme">
                    <span class={`material-symbols-outlined ${styles.themeToggleIcon} ${styles.sun}`}>light_mode</span>
                    <span class={`material-symbols-outlined ${styles.themeToggleIcon} ${styles.moon}`}>dark_mode</span>
                </button>

                <button class={styles.hamburger} id="menu-toggle" aria-label="Menu">
                    <div class={styles.hamburgerLine}></div>
                    <div class={styles.hamburgerLine}></div>
                    <div class={styles.hamburgerLine}></div>
                </button>
            </div>
        </header>

        <!-- Flashy Lateral Menu Overlay -->
        <nav class={styles.menuOverlay} id="menu-overlay">
            <button class={styles.closeMenu} id="close-menu" aria-label="Close Menu">
                <span class={`material-symbols-outlined ${styles.closeIcon}`}>close</span>
            </button>
            <div class={styles.menuNav}>
                <a href="/" class={styles.menuLink}>Inicio</a>
                <a href="/explorador" class={styles.menuLink}>Explorador</a>
                <a href="/rutas" class={styles.menuLink}>Planificar viaje</a>
                <a href="#" class={styles.menuLink}>Favoritos</a>
            </div>
        </nav>

        <div class={styles.shell}>
            {/* Sidebar */}
            {!hideSidebar && (
            <aside class={`${styles.sidebar} custom-scrollbar`}>
                {/* Logo Section */}
                <div class={styles.brandSection}>
                    <div class={styles.brandContainer}>
                        <div class={styles.logoBox}>
                            <img
                                src="/images/logo-octo.png"
                                alt="OCTO Logo"
                                class={styles.logoImage}
                            />
                        </div>
                        <p class={styles.brandSubtitle}>
                            Menos gasto, más kilómetros
                        </p>
                    </div>
                </div>

                <!-- Navigation -->
                <nav class={styles.nav}>
                    <a
                        href="/"
                        class={`${styles.navItem} ${Astro.url.pathname === "/" ? styles.active : ""}`}
                    >
                        <span
                            class={`material-symbols-outlined ${styles.navIcon}`}
                            >home</span
                        >
                        <span class={styles.navLabel}
                            >Inicio</span
                        >
                    </a>
                    <a
                        href="/explorador"
                        class={`${styles.navItem} ${Astro.url.pathname === "/explorador" ? styles.active : ""}`}
                    >
                        <span
                            class={`material-symbols-outlined ${styles.navIcon}`}
                            >explore</span
                        >
                        <span class={styles.navLabel}
                            >Explorador de Precios</span
                        >
                    </a>
                    <a
                        href="/rutas"
                        class={`${styles.navItem} ${Astro.url.pathname === "/rutas" ? styles.active : ""}`}
                    >
                        <span
                            class={`material-symbols-outlined ${styles.navIcon}`}
                            >route</span
                        >
                        <span class={styles.navLabel}>Planificar viaje</span>
                    </a>
                    <div class={styles.navItem}>
                        <span
                            class={`material-symbols-outlined ${styles.navIcon}`}
                            >favorite</span
                        >
                        <span class={styles.navLabel}>Favoritos</span>
                    </div>
                </nav>

                <div class={styles.divider}></div>

                {
                    /* Sidebar content that might be specific to index or shared. 
                    For now, keeping the static structure but we might want to make it flexible via slots if needed.
                    The dynamic page only needs the shell, maybe not all the controls.
                    But to keep consistency, I'll include the shell.
                */
                }

                <!-- User Profile -->
                <div class={styles.userProfile}>
                    <div class={styles.profileContent}>
                        <div class={styles.avatar}>
                            <span
                                class={`material-symbols-outlined ${styles.avatarIcon}`}
                                >person</span
                            >
                        </div>
                        <div class={styles.userDetails}>
                            <p class={styles.userName}>Diego Martínez</p>
                            <p class={styles.userRole}>Socio Premium OCTO</p>
                        </div>
                        <button style={{ color: "#64748b" }}>
                            <span class="material-symbols-outlined"
                                >settings</span
                            >
                        </button>
                    </div>
                </div>
            </aside>
            )}

            <!-- Main Content -->
            <main class={styles.main}>
                <slot />
            </main>
        </div>

        <ConsentBanner />
    </body>
    <script>
        document.addEventListener("DOMContentLoaded", () => {
            const bodyTag = document.body;
            const menuToggle = document.getElementById('menu-toggle');
            const themeToggle = document.getElementById('theme-toggle');
            const closeMenuBtn = document.getElementById('close-menu');
            const menuLinks = document.querySelectorAll('#menu-overlay a');
            const htmlElement = document.documentElement;

            // Hamburger Menu Toggle
            menuToggle?.addEventListener('click', () => {
                bodyTag.classList.toggle('menu-open');
            });

            // Close Menu
            closeMenuBtn?.addEventListener('click', () => {
                bodyTag.classList.remove('menu-open');
            });

            menuLinks.forEach(link => {
                link.addEventListener('click', () => {
                    bodyTag.classList.remove('menu-open');
                });
            });

            // Light/Dark Mode Toggle
            const initTheme = () => {
                const savedTheme = localStorage.getItem('theme');
                const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
                
                if (savedTheme === 'light') {
                    htmlElement.setAttribute('data-theme', 'light');
                    themeToggle?.classList.remove('is-dark');
                } else if (savedTheme === 'dark' || prefersDark) {
                    htmlElement.removeAttribute('data-theme');
                    themeToggle?.classList.add('is-dark');
                } else {
                    htmlElement.removeAttribute('data-theme');
                    themeToggle?.classList.add('is-dark');
                }
            };

            initTheme();

            themeToggle?.addEventListener('click', () => {
                const isDarCurrently = themeToggle.classList.contains('is-dark');
                if (isDarCurrently) {
                    htmlElement.setAttribute('data-theme', 'light');
                    localStorage.setItem('theme', 'light');
                    themeToggle.classList.remove('is-dark');
                } else {
                    htmlElement.removeAttribute('data-theme');
                    localStorage.setItem('theme', 'dark');
                    themeToggle.classList.add('is-dark');
                }
            });
        });
    </script>
</html>
